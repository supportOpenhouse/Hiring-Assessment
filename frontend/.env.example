# Local development env for the frontend (copy to frontend/.env).
# On Vercel set only VITE_GOOGLE_CLIENT_ID — leave VITE_API_BASE unset so the
# SPA calls the same-origin /api function.

VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Local dev only — points the SPA at the local backend.
VITE_API_BASE=http://localhost:4000
