# Local development env for the backend (copy to backend/.env).
# In production all of these are set on the single Vercel project instead.

# Postgres (Vercel Postgres / Neon / local)
POSTGRES_URL=postgres://user:password@localhost:5432/openhouse_assessment

# Google OAuth Web client
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Random string — signs session JWTs
SESSION_SECRET=change-me

# Comma-separated admin emails
ADMIN_EMAILS=ashish@openhouse.in

# Vercel Blob store token (uploads)
BLOB_READ_WRITE_TOKEN=

# AI scoring
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_API_KEY=

# Protects /api/cron/score (Vercel sets the header automatically in prod)
CRON_SECRET=change-me

# Local dev only — CORS origin for the Vite dev server.
# Not needed in production (frontend + API share one origin).
FRONTEND_ORIGIN=http://localhost:5173

# PORT=4000
